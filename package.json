{
  "name": "prepdog",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "build:firebase-static": "node scripts/build-firebase-static.mjs",
    "deploy:firebase-static": "pnpm build:firebase-static && firebase deploy --only hosting",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @prepdog/assessment test",
    "import:prepdog": "tsx scripts/import-prepdog.ts",
    "reset:prepdog-content": "tsx scripts/reset-imported-content.ts",
    "reimport:prepdog-grades-2-6": "tsx scripts/reimport-grades-2-6.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}